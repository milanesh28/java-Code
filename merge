package placement;

public class merge {
    public static void main(String[] args) {
        int[] a = {1, 2, 3};
        int[] b = {4, 5, 6};

        int[] c = new int[a.length + b.length];
        int k = 0;

        for (int i : a) c[k++] = i;
        for (int i : b) c[k++] = i;

        for (int i : c)
            System.out.print(i + " ");
    }
}
