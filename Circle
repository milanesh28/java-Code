package placement;

import java.util.Scanner;

public class Circle {

	public static void main(String[] args) 
	{
		double r,area;
		public void getdata()
		{
			Scanner in=new Scanner(System.in);
			System.out.println("Enter r:");
			r=in.nextDouble();
		}
		public void calc()
		{
			area=314*r*r;
			System.out.print("Area="+area);
		}
	}
class Main
{
	public static void main(String[] args) {
		Circle obj=new Circle();
		obj.getdata();
		obj.calc();
	}
}
	}


